DATABASE_URL=postgresql+asyncpg://your_db_user:your_db_password@your-db-host/your_db_name
DATABASE_URL_SYNC=postgresql://your_db_user:your_db_password@your-db-host/your_db_name

POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name

LOG_LEVEL=INFO
ENVIRONMENT=development
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Comma-separated origins for browser access
# Example: CORS_ORIGINS=https://clinqer.netlify.app,https://your-tunnel.trycloudflare.com
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
