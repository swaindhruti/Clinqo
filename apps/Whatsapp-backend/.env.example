DATABASE_URL=postgresql+asyncpg://your_db_user:your_db_password@your-db-host/your_db_name
DATABASE_URL_SYNC=postgresql://your_db_user:your_db_password@your-db-host/your_db_name

LOG_LEVEL=INFO
ENVIRONMENT=production
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Browser origins allowed to call the API
# Example: CORS_ORIGINS=https://clinqer.netlify.app,http://localhost:3000,http://localhost:8080
CORS_ORIGINS=https://clinqer.netlify.app,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080
CORS_ALLOW_CREDENTIALS=false
